# Environment Configuration Example
# Copy this file to .env and fill in real values
# NEVER commit .env with real secrets!

# ─────────────────────────────────────────────────────────────
# Node.js / Server Configuration
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────────────────────
# Frontend URL
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-url.vercel.app

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vendor_connect

# ─────────────────────────────────────────────────────────────
# Redis (Message Queue & Caching)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# WhatsApp Cloud API (Meta)
# Get from: https://developers.facebook.com/apps
# ─────────────────────────────────────────────────────────────
# Webhook verification token (you create this - must be strong)
VERIFY_TOKEN=your-strong-webhook-verify-token-here

# WhatsApp Business Account Access Token
# Get from your Meta Business Account > Settings > System Users > Generate
ACCESS_TOKEN=your-meta-whatsapp-access-token-here

# ─────────────────────────────────────────────────────────────
# AI / LLM Configuration (Optional)
# ─────────────────────────────────────────────────────────────
# Google Gemini API Key (for AI-powered order extraction)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# Vercel Deployment (if using Vercel)
# ─────────────────────────────────────────────────────────────
# Set in Vercel dashboard under Project Settings > Environment Variables
# DO NOT set these in local .env for production values
