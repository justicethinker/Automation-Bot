# API Server Environment Variables
# Copy this file to .env in the api-server directory and fill in real values
# DO NOT commit actual .env files with real secrets

# ─────────────────────────────────────────────────────────────
# Node.js / Server Configuration
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────────────────────
# Frontend URL
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-url.vercel.app

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vendor_connect

# ─────────────────────────────────────────────────────────────
# Redis (Message Queue & Caching)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# WhatsApp Cloud API (Meta)
# ─────────────────────────────────────────────────────────────
# Webhook verification token (you create this - must be strong and unique)
VERIFY_TOKEN=your-strong-webhook-verify-token-here

# WhatsApp Business Account Access Token
# Get from your Meta Business Account
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
ACCESS_TOKEN=your-meta-whatsapp-access-token-here

# ─────────────────────────────────────────────────────────────
# Google Gemini API (Optional, for AI-powered extraction)
# ─────────────────────────────────────────────────────────────
# Get your key at: https://makersuite.google.com/app/apikey
# If not set, bot falls back to rule-based extraction
GEMINI_API_KEY=AIzaSy_your-gemini-api-key-here

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

